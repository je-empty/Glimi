# Glimi E2E QA 로컬 설정 템플릿
# 사용법:  cp tests/e2e/qa.env.example communities/qa/.env  후 값 채우기
# (communities/ 는 gitignore — 토큰·개인정보가 커밋되지 않는다)
#
# 준비물: QA 전용 디스코드 서버 1개 + 봇 2개
#   1) 에이전트 봇  (DISCORD_BOT_TOKEN) — 평소 운영 봇과 별개의 QA 전용 봇 권장
#   2) 테스트 유저 봇 (TEST_BOT_TOKEN)  — "가짜 오너" 역할로 발화하는 봇
# 두 봇 모두 QA 서버에 초대 + Message Content Intent 활성화.

DISCORD_BOT_TOKEN=
TEST_BOT_TOKEN=
DISCORD_GUILD_ID=

# ── QA 페르소나 = 자기 자신 ──────────────────────────────
# 에이전트들이 이 사람을 오너로 인식하고 기억·관계를 쌓는다.
# 본인 이름/호칭으로 채워야 호칭 처리·기억 추출 같은 로직이
# 실사용과 같은 조건으로 검증된다. (미설정 시 기본값: 김도윤)
QA_USER_NAME=김도윤
QA_USER_NICKNAME=도윤
QA_USER_AGE=26
QA_USER_BIRTH_YEAR=2001
QA_USER_GENDER=남
